# ============================================================================
# Aliran environment. Copy to .env and fill in. See BLOCKED.md for what each
# unblocks and the exact command to run once you have it.
# ============================================================================

# --- Mode -------------------------------------------------------------------
# MOCK_MODE=true  -> Venice returns canned responses; chain calls are dry-run
#                    (constructed + signed locally if possible, logged, NOT broadcast).
# MOCK_MODE=false -> real Venice + real on-chain broadcast (needs everything below).
MOCK_MODE=true

# DEMO_MODE controls who the owner signer is:
#   env-key -> owner is OWNER_PRIVATE_KEY (no wallet popups; good for recording)
#   wallet  -> owner signer is the browser MetaMask wallet (shown in UI)
DEMO_MODE=env-key

# --- Scaled demo amounts (optional; defaults shown are the full-size figures) -
# For real runs on scarce faucet USDC, set small values, e.g. 8 / 4 / 2.5 / 1 /
# 0.5 / 0.05. Leave unset for the original 500/300/150/50 figures.
DEMO_ROOT_CAP_USDC=500
DEMO_CAP_PAYROLL=300
DEMO_CAP_PROCUREMENT=150
DEMO_CAP_CREATIVE=50
DEMO_PAYROLL_PER_TASK_USDC=0
DEMO_X402_PRICE_USD=0.01

# --- Chain (Base Sepolia) ---------------------------------------------------
CHAIN_ID=84532
RPC_URL=
# ERC-4337 bundler RPC (required for redeemDelegations userOps). e.g. Pimlico.
BUNDLER_URL=
# Base Sepolia USDC. Verify on the supported-networks / token docs before real mode.
USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- Accounts (private keys, 0x-prefixed) -----------------------------------
OWNER_PRIVATE_KEY=
AGENT_CFO_PK=
AGENT_PAYROLL_PK=
AGENT_PROCUREMENT_PK=
AGENT_CREATIVE_PK=
# 2-3 plain EOA receivers, comma-separated
CONTRIBUTOR_ADDRESSES=

# --- Venice AI --------------------------------------------------------------
VENICE_API_KEY=
VENICE_BASE_URL=https://api.venice.ai/api/v1
VENICE_MODEL=
VENICE_IMAGE_MODEL=

# --- x402 seller ------------------------------------------------------------
SELLER_PORT=4021
SELLER_PAY_TO_ADDRESS=
# MetaMask x402 facilitator. Base Sepolia:
# https://tx-sentinel-base-sepolia.dev-api.cx.metamask.io/platform/v2/x402
X402_FACILITATOR_URL=
# Facilitator settlement address the buyer's open delegation is restricted to
# (RedeemerEnforcer caveat). With the official seller middleware this is returned
# in the 402 challenge, so it can be left blank.
X402_FACILITATOR_ADDRESS=
# x402 transport: 'real' = official @x402 client + MetaMask facilitator (the
# facilitator settles on-chain); 'mock' = local stub (emergency fallback).
X402_MODE=real
# Dedicated x402 buyer EOA. The facilitator requires an EIP-7702-upgraded payer,
# so x402 purchases use this account (NOT the procurement Hybrid account).
# Provision it with `pnpm x402:setup` (generates the key, funds from owner, and
# submits the EIP-7702 upgrade). Leave blank; the setup script fills it.
X402_BUYER_PK=
SELLER_URL=http://localhost:4021

# --- M6: 1Shot permissionless relayer (Base MAINNET 8453, stretch) ----------
# Fully isolated from the Sepolia demo: only `RELAYER=1shot pnpm m6` reads these.
# The owner is a real mainnet EOA holding USDC and ZERO ETH (gas paid in USDC).
RELAYER=
MAINNET_OWNER_PK=
MAINNET_RPC_URL=https://mainnet.base.org
MAINNET_USDC=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
RELAYER_URL=https://relayer.1shotapi.com/relayers
M6_WORK_RECIPIENT=
